# Kopjoje këtë file si ".env" dhe plotëso vlerat
# Lidhja me databazën PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/pcstyle?schema=public"

# NextAuth - gjenero një sekret me: openssl rand -base64 32
NEXTAUTH_SECRET="ndrysho-kete-sekret-shume-te-gjate"
NEXTAUTH_URL="http://localhost:3000"

# URL publike e website (per SEO / sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
