// ============================================================
// PC-STYLE - Skema e databazës (PostgreSQL + Prisma ORM)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Rolet dhe statuset ----------

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING // Në pritje
  PROCESSING // Në përpunim
  SHIPPED // Dërguar
  DELIVERED // Dorëzuar
  CANCELLED // Anuluar
}

// ---------- Përdoruesit ----------

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String // hash me bcrypt - asnjëherë plaintext
  role       Role     @default(USER)
  isActive   Boolean  @default(true) // admini mund të bllokojë përdorues
  resetToken String? // token për "Forgot Password"
  resetTokenExpiry DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@index([email])
}

// ---------- Kategoritë ----------

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String? // emri i ikonës lucide
  products Product[]
}

// ---------- Produktet ----------

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String // përshkrim profesional teknologjik
  price       Decimal  @db.Decimal(10, 2)
  oldPrice    Decimal? @db.Decimal(10, 2) // për oferta / zbritje
  brand       String
  stock       Int      @default(0)
  images      String[] // galeri fotosh (URL)
  specs       Json // specifikime teknike { "Çelësi": "Vlera" }
  featured    Boolean  @default(false) // shfaqet në Hero / faqen kryesore
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]

  @@index([categoryId])
  @@index([brand])
  @@index([slug])
}

// ---------- Porositë ----------

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique // p.sh. PCS-2026-0001
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  status       OrderStatus @default(PENDING)
  total        Decimal     @db.Decimal(10, 2)
  // Të dhënat e dërgesës
  fullName     String
  email        String
  phone        String
  address      String
  city         String
  zip          String
  note         String?
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String // ruajmë emrin/çmimin në momentin e blerjes
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  image     String?
}

// ---------- Mesazhet e kontaktit ----------

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
